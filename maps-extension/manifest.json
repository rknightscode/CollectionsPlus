{
  "manifest_version": 3,
  "name": "Google Maps Search",
  "version": "1.0",
  "description": "Right-click any text to search Google Maps, and automatically redirects UK postcodes to Google Maps.",
  "permissions": [
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://www.bing.com/*",
    "https://www.google.co.uk/*",
    "https://www.google.com/*",
    "https://duckduckgo.com/*",
    "https://search.yahoo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Google Maps Search"
  }
}
