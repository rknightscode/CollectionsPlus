{
  "manifest_version": 3,
  "name": "Archive.is Button",
  "version": "1.0",
  "description": "Quickly archive the current page using archive.is",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Archive this page"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
