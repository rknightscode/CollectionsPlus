{
  "manifest_version": 3,
  "name": "OnlineCheckPlus",
  "version": "2.0.0",
  "description": "Right-click selected text to check SRA, Companies House, ICO, or HMRC VAT registers.",
  "permissions": [
    "contextMenus",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://solicitors.lawsociety.org.uk/*",
    "https://ico.org.uk/*",
    "https://www.tax.service.gov.uk/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "OnlineCheckPlus",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
